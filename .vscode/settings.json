// Place your settings here. See https://github.com/dart-code/Dart-Code/wiki/Recommended-Settings for recommended settings.
{
  "dart.flutterSdkPath": "${workspaceFolder}",
  "dart.enableSdkFormatter": true,
  "dart.lineLength": 100,
  "[dart]": {
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "editor.rulers": [80, 100],
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/build": true,
    "**/.dart_tool": true,
    "**/ios": true,
    "**/android": true,
    "**/web": true,
    "**/windows": true,
    "**/linux": true,
    "**/macos": true
  }
}
